{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "installCommand": "npm install",
    "buildCommand": "npx medusa build"
  },
  "deploy": {
    "startCommand": "npx medusa start",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}
